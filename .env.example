# ==============================================================================
# Yurttaş Mutfakta - Ortam Değişkenleri Şablonu (.env.example)
# ==============================================================================
# DİKKAT: Bu dosya sadece bir şablondur ve GitHub'a yüklenebilir.
# Gerçek API anahtarlarınızı ASLA bu dosyaya yazmayın.
# Kullanım: Bu dosyayı kopyalayın, adını '.env' yapın ve kendi değerlerinizi girin.
# ==============================================================================

# ------------------------------------------------------------------------------
# 🗄️ SUPABASE AYARLARI
# Supabase projenizin "Project Settings -> API" bölümünden bu değerleri alabilirsiniz.
# ------------------------------------------------------------------------------
VITE_SUPABASE_URL="https://[PROJE_ID_BURAYA].supabase.co"
VITE_SUPABASE_ANON_KEY="[SUPABASE_ANON_ANAHTARI_BURAYA]"

# ------------------------------------------------------------------------------
# 🤖 YAPAY ZEKA (AI) API AYARLARI
# Projede kullanılan AI sağlayıcısının (Gemini, OpenAI, Anthropic vb.) anahtarları.
# ------------------------------------------------------------------------------
VITE_AI_API_KEY="[AI_SERVIS_ANAHTARI_BURAYA]"

# (Opsiyonel) Farklı sağlayıcılar için spesifik anahtarlar kullanıyorsanız:
# VITE_OPENAI_API_KEY="sk-[OPENAI_ANAHTARI_BURAYA]"
# VITE_GEMINI_API_KEY="[GEMINI_ANAHTARI_BURAYA]"
# VITE_OPENROUTER_API_KEY="sk-or-v1-[OPENROUTER_ANAHTARI_BURAYA]"

# ------------------------------------------------------------------------------
# ⚙️ GENEL UYGULAMA AYARLARI
# ------------------------------------------------------------------------------
NODE_ENV="development"
# VITE_APP_URL="http://localhost:5173"
