# ==============================================================================
# Yurttaş Mutfakta - Ortam Değişkenleri Şablonu (.env.example)
# ==============================================================================

# SUPABASE AYARLARI
# -----------------
# Frontend (Vite) için gerekenler:
VITE_SUPABASE_URL="https://[PROJE_ID_BURAYA].supabase.co"
VITE_SUPABASE_ANON_KEY="[SUPABASE_ANON_ANAHTARI_BURAYA]"
VITE_SUPABASE_PROJECT_ID="[PROJE_ID_BURAYA]"

# Backend/Sunucu tarafı için gerekenler:
SUPABASE_URL="https://[PROJE_ID_BURAYA].supabase.co"
SUPABASE_ANON_KEY="[SUPABASE_ANON_ANAHTARI_BURAYA]"
SUPABASE_PROJECT_ID="[PROJE_ID_BURAYA]"

# AI AYARLARI
# -----------
VITE_AI_API_KEY="[AI_SERVIS_ANAHTARI_BURAYA]"

# GENEL AYARLAR
# -------------
NODE_ENV="development"
